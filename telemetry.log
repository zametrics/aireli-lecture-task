st registerUser = async (req: Request, res: Response): Promise<void> => {\n  const { email, password } = req.body;\n\n  if (!email || !password) {\n    res.status(400).json({ message: 'Email and password are required' });\n    return;\n  }\n\n  const newUser: PlatformUser = {\n    id: null,\n    email,\n    password\n  };\n\n  try {\n    const user = await createUser(newUser);\n\n    if (!user || user.id == null) {\n      res.status(500).json({ message: 'User could not be created' });\n      return;\n    }\n\n    const accessToken = jwt.sign(\n      { id: user.id },\n      process.env.JWT_SECRET || \"no_key_set\",\n      { expiresIn: '1h' }\n    );\n\n    const expiresAt = new Date(Date.now() + 3600 * 1000).toISOString();\n\n    res.status(201).json({\n      user,\n      accessToken,\n      expiresAt\n    });\n  } catch (error: any) {\n    if (error?.message?.includes('UNIQUE constraint failed')) {\n      res.status(409).json({ message: 'Email already exists' });\n      return;\n    }\n\n    res.status(500).json({ message: 'Registration failed' });\n  }\n};","rangeOffset":"194","rangeLength":"238","rangestart_line":"5","rangestart_character":"0","rangeend_line":"15","rangeend_character":"2"},{"codespaceName":"expert-space-sniffle-v7q7r7w7wpwh69p5","eventName":"DocumentSaveEvent","eventTime":1773678153180,"sessionId":"a73ef66e-8bce-47f0-b3dc-58a5e8330cca1773675922807","machineId":"e3bc2d4ca8d298a4a66776b479b4bf4d767ae81016d9eb3890475e9efb9512ff","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":15,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"expert-space-sniffle-v7q7r7w7wpwh69p5","eventName":"DocumentSaveEvent","eventTime":1773678155738,"sessionId":"a73ef66e-8bce-47f0-b3dc-58a5e8330cca1773675922807","machineId":"e3bc2d4ca8d298a4a66776b479b4bf4d767ae81016d9eb3890475e9efb9512ff","docume