ine":"0","rangeend_character":"0"},{"codespaceName":"expert-space-sniffle-v7q7r7w7wpwh69p5","eventName":"WindowStateChangeEvent","eventTime":1773678688358,"sessionId":"a73ef66e-8bce-47f0-b3dc-58a5e8330cca1773675922807","machineId":"e3bc2d4ca8d298a4a66776b479b4bf4d767ae81016d9eb3890475e9efb9512ff","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"expert-space-sniffle-v7q7r7w7wpwh69p5","eventName":"ActiveEditorChangeEvent","eventTime":1773678693256,"sessionId":"a73ef66e-8bce-47f0-b3dc-58a5e8330cca1773675922807","machineId":"e3bc2d4ca8d298a4a66776b479b4bf4d767ae81016d9eb3890475e9efb9512ff","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":22,"operation":"focus","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"expert-space-sniffle-v7q7r7w7wpwh69p5","eventName":"DocumentChangeEvent","eventTime":1773678695322,"sessionId":"a73ef66e-8bce-47f0-b3dc-58a5e8330cca1773675922807","machineId":"e3bc2d4ca8d298a4a66776b479b4bf4d767ae81016d9eb3890475e9efb9512ff","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":22,"operation":"replace","value":"import bcrypt from 'bcryptjs';\nimport { PlatformUser } from \"@enterprise-commerce/core/platform/types\";\nimport openDb from '../db/db';\n\nexport const createUser = async (\n  user: PlatformUser\n): Promise<Pick<PlatformUser, \"id\"> | null> => {\n  const db = await openDb();\n\n  try {\n    const hashedPassword = await bcrypt.hash(user.password, 10);\n\n    const result = await db.run(\n      `INSERT INTO users (email, password) VALUES (?, ?)`,\n      user.email,\n      hashedPassword\n    );\n\n    return { id: String(result.lastID) };\n  } finally {\n    await db.close();\n  }\n};\n\nexport const findUserById = async (id: string): Promise<PlatformUser | null> => {\n  const db = await openDb();\n  const user = await db.get<PlatformUser>('SELECT * FROM users WHERE id = ?', id);\n  await db.close();\n  return user || null;\n};\n\nexport const comparePasswords = async (password: string, hashedPassword: string): Promise<boolean> => {\n  return bcrypt.compare(password, hashedPassword); \n};","rangeOffset":"232","rangeLength":"433","rangestart_line":"7","rangestart_character":"0","rangeend_line":"27","rangeend_character":"0"},{"codespaceName":"expert-space-sniffle-v7q7r7w7wpwh69p5","eventName":"DocumentCloseEvent","eventTime":1773678696214,"sessionId":"a73ef66e-8bce-47f0-b3dc-58a5e8330cca1773675922807","machineId":"e3bc2d4ca8d298a4a66776b479b4bf4d767ae81016d9eb3890475e9efb9512ff","documentUri":"file:///workspaces/aireli-lecture-task/packages/core/platform/types.ts","documentId":23,"operation":"close","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"expert-space-sniffle-v7q7r7w7wpwh69p5","eventName":"DocumentChangeEvent","eventTime":1773678698130,"sessionId":"a73ef66e-8bce-47f0-b3dc-58a5e8330cca1773675922807","machineId":"e3bc2d4ca8d298a4a66776b479b4bf4d767ae81016d9eb3890475e9efb9512ff","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":22,"operation":"delete","value":"","rangeOffset":"232","rangeLength":"135","rangestart_line":"7","rangestart_character":"0","rangeend_line":"10","rangeend_character":"0"},{"codespaceName":"expert-space-sniffle-v7q7r7w7wpwh69p5","eventName":"DocumentCloseEvent","eventTime":1773678699682,"sessionId":"a73ef66e-8bce-47f0-b3dc-58a5e8330cca1773675922807","machineId":"e3bc2d4ca8d298a4a66776b479b4bf4d767ae81016d9eb3890475e9efb9512ff","documentUri":"file:///workspaces/aireli-lecture-task/node_modules/sqlite/build/interfaces.d.ts","documentId":33,"operation":"close","rangeOffset":"0","rangeLength":